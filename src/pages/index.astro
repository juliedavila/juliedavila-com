---
import '../styles/tokens.css';

// ─────────────────────────────────────────────────────────────────────────────
// JULIE'S VOICE SLOTS — these three are hers. Camila does not write them.
// Until they are filled, the build fails loudly (see the guard below) rather
// than shipping placeholder prose to a public homepage.
//
// Rules from the council:
//   IDENTITY = a CATEGORY, not a job. A job expires on your last day; a
//              category outlives every employer. (Shortridge: "product
//              executive in B2B infrastructure software.")
//   THESIS   = a falsifiable claim. Something a peer could argue with.
//   BRECHA   = one sentence where the word does labor as the noun for the gap.
//              It does NOT explain the name. Explaining a name performs depth.
// ─────────────────────────────────────────────────────────────────────────────

const IDENTITY = 'Security executive for enterprise-class platform providers'; // settled 2026-07-13 (do not re-open)
const THESIS   = 'Security does not choose its own backlog; it derives that mandate from the value streams the business runs on and the quality its market demands. It reserves its deepest scrutiny for where a failure is material, not where it is loud: the blast radius that spreads, the crown jewel that cannot be lost.'; // Council-vetted + Julie-ratified 2026-07-16
const BRECHA   = ''; // ← Julie (optional at Stage 1; can land at Stage 2)

// Build guard: no placeholder ever reaches the public apex.
if (import.meta.env.PROD && (!IDENTITY || !THESIS)) {
  throw new Error(
    'BLOCKED: IDENTITY and THESIS are empty in src/pages/index.astro. ' +
    "These are Julie's slots. Fill them before deploying to juliedavila.com."
  );
}

// In dev only, show the empty slots as visible markers so the layout can be
// reviewed without anyone putting words in her mouth.
const identity = IDENTITY || '[ IDENTITY LINE — a category, not a job ]';
const thesis   = THESIS   || '[ THESIS — a falsifiable claim a peer could argue with ]';
const brecha   = BRECHA;

const META_DESCRIPTION = IDENTITY; // never the word "practitioner" again

// Everything below is IMMUTABLE or SELF-UPDATING. Nothing hand-maintained
// that can silently rot. Past only — "upcoming" is what goes stale.
const work = [
  {
    name: 'SF² — the Software Factory Security Framework',
    href: 'https://sf2framework.com',
    note: 'Open framework, CC BY 4.0. Security constraints as part of the spec.',
  },
];

// Past. Dated. Real titles. A record, not a sizzle reel.
const appearances = [
  {
    date: '2026',
    title: 'Keynote — SANS AI Cybersecurity Summit',
    href: 'https://www.sans.org/ai-cybersecurity-summit-2026',
  },
  {
    date: '2025',
    title: 'AI, Identity & Trust',
    href: 'https://www.youtube.com/watch?v=ozicRdb0LX8',
  },
  {
    date: '2024',
    title: 'Crying Out Cloud — From NASA to GitLab',
    href: 'https://www.wiz.io/crying-out-cloud/from-nasa-to-gitlab-democratizing-security-open-source-and-empowering-women-with',
  },
];

const elsewhere = [
  { name: 'LinkedIn', href: 'https://linkedin.com/in/thisjulie' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Julie Davila</title>
  <meta name="description" content={META_DESCRIPTION} />
  <meta property="og:title" content="Julie Davila" />
  <meta property="og:description" content={META_DESCRIPTION} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://juliedavila.com" />
  <link rel="canonical" href="https://juliedavila.com" />
</head>

<body>
  <main>
    <header class="fold">
      <h1>Julie Davila</h1>
      <p class="identity" class:list={[{ slot: !IDENTITY }]}>{identity}</p>
      <p class="thesis" class:list={[{ slot: !THESIS }]}>{thesis}</p>
      {brecha && <p class="brecha">{brecha}</p>}
    </header>

    <hr />

    <section>
      <h2>Work</h2>
      <ul class="list">
        {work.map((w) => (
          <li>
            <a href={w.href}>{w.name}</a>
            <span class="note">{w.note}</span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Talks &amp; appearances</h2>
      <ul class="list dated">
        {appearances.map((a) => (
          <li>
            <span class="date">{a.date}</span>
            <a href={a.href}>{a.title}</a>
          </li>
        ))}
      </ul>
    </section>

    <hr />

    <!-- The one action. The only terracotta on the page.
         Stage 2: this becomes the La Brecha subscribe, posting to Ghost. -->
    <section class="action">
      <p class="soon">La Brecha — essays on the gaps, launching soon.</p>
      <a class="cta" href="mailto:julie@davila.io?subject=La%20Brecha">Tell me when it&rsquo;s live</a>
    </section>

    <footer>
      {elsewhere.map((e) => <a href={e.href}>{e.name}</a>)}
      <a href="mailto:julie@davila.io">Email</a>
    </footer>
  </main>
</body>
</html>

<style>
  main {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 14vh 1.5rem 8rem;
  }

  .fold { margin-bottom: 3.5rem; }

  h1 {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
  }

  .identity {
    font-size: 1.75rem;
    line-height: 1.35;
    color: var(--azul);
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .thesis {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 1.25rem;
  }

  .brecha {
    font-size: 1.05rem;
    color: var(--ink-soft);
    font-style: italic;
    margin: 0;
  }

  /* Dev-only affordance: an unfilled slot looks like an unfilled slot. */
  .slot {
    color: var(--ink-faint);
    font-family: var(--sans);
    font-size: 0.95rem;
    font-style: normal;
    background: var(--sand-deep);
    border: 1px dashed var(--rule);
    padding: 0.5rem 0.75rem;
    display: inline-block;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--gold);
    margin: 3.5rem 0;
  }

  h2 {
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 1.25rem;
  }

  section { margin-bottom: 3rem; }

  .list { list-style: none; padding: 0; margin: 0; }
  .list li { margin-bottom: 1.1rem; line-height: 1.5; }

  .note {
    display: block;
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin-top: 0.15rem;
  }

  .dated li {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 0.5rem;
    align-items: baseline;
  }

  .date {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }

  .action { margin: 0 0 4rem; }

  .soon {
    font-size: 1.05rem;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  /* The single terracotta. If you are adding a second one, stop. */
  .cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: var(--terracotta);
    border: 1px solid var(--terracotta);
    border-bottom: 1px solid var(--terracotta);
    padding: 0.6rem 1.1rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .cta:hover {
    background: var(--terracotta);
    color: var(--sand);
  }

  footer {
    display: flex;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    font-family: var(--sans);
    font-size: 0.88rem;
  }
  footer a { color: var(--ink-soft); border-bottom: none; }
  footer a:hover { color: var(--azul); }

  @media (max-width: 34rem) {
    main { padding-top: 8vh; }
    .identity { font-size: 1.45rem; }
    .dated li { grid-template-columns: 3rem 1fr; }
  }
</style>
