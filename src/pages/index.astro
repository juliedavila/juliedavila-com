---
import '../styles/tokens.css';

// ─────────────────────────────────────────────────────────────────────────────
// VOICE SLOTS — IDENTITY and THESIS are Julie's. Both filled + Council-vetted.
//   IDENTITY = a CATEGORY, not a job.
//   THESIS   = a falsifiable claim a peer could argue with.
//   BRECHA   = one sentence where the word does labor as the noun for the gap.
// ─────────────────────────────────────────────────────────────────────────────

const IDENTITY = 'Security executive for enterprise platform providers';
const THESIS   = 'I build efficient, AI-native security organizations that make R&D value streams faster, while treating security as an emergent property of how the business delivers value to its customers.';
const BRECHA   = '';

// Build guard: no placeholder ever reaches the public apex.
if (import.meta.env.PROD && (!IDENTITY || !THESIS)) {
  throw new Error(
    'BLOCKED: IDENTITY and THESIS are empty in src/pages/index.astro. ' +
    "These are Julie's slots. Fill them before deploying to juliedavila.com."
  );
}

const identity = IDENTITY || '[ IDENTITY LINE — a category, not a job ]';
const thesis   = THESIS   || '[ THESIS — a falsifiable claim a peer could argue with ]';
const brecha   = BRECHA;

const META_DESCRIPTION = IDENTITY;

// Everything below is IMMUTABLE or SELF-UPDATING. Past only — "upcoming" rots.
const work = [
  {
    name: 'SF² — the Software Factory Security Framework',
    href: 'https://sf2framework.com',
    note: 'Open framework, CC BY 4.0. Security constraints as part of the spec.',
  },
];

// Bylined writing — her own thinking, in public. Verified live 2026-07-16.
const writing = [
  {
    date: '2026',
    title: 'The 2 Failures With AI Coding That Are Creating Security Bottlenecks',
    outlet: 'The New Stack',
    href: 'https://thenewstack.io/ai-coding-security-bottlenecks/',
  },
  {
    date: '2025',
    title: 'Beyond the Hype: 4 Ways To Use AI for Cybersecurity Defenses',
    outlet: 'The New Stack',
    href: 'https://thenewstack.io/beyond-the-hype-4-ways-to-use-ai-for-cybersecurity-defenses/',
  },
];

// Past. Dated. Real titles. A record, not a sizzle reel. Verified live 2026-07-16.
const appearances = [
  {
    date: '2026',
    title: 'Keynote — SANS AI Cybersecurity Summit',
    href: 'https://www.sans.org/ai-cybersecurity-summit-2026',
  },
  {
    date: '2025',
    title: 'Embrace AI Without Losing Control — LeadDev',
    href: 'https://leaddev.com/event/embrace-ai-without-losing-control',
  },
  {
    date: '2025',
    title: 'AI, Identity & Trust',
    href: 'https://www.youtube.com/watch?v=ozicRdb0LX8',
  },
  {
    date: '2024',
    title: 'Crying Out Cloud — From NASA to GitLab',
    href: 'https://www.wiz.io/crying-out-cloud/from-nasa-to-gitlab-democratizing-security-open-source-and-empowering-women-with',
  },
];

const elsewhere = [
  { name: 'LinkedIn', href: 'https://linkedin.com/in/thisjulie' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Julie Davila</title>
  <meta name="description" content={META_DESCRIPTION} />
  <meta property="og:title" content="Julie Davila" />
  <meta property="og:description" content={META_DESCRIPTION} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://juliedavila.com" />
  <meta property="og:image" content="https://juliedavila.com/portrait-azul.png" />
  <link rel="canonical" href="https://juliedavila.com" />
</head>

<body>
  <main>
    <header class="fold">
      <div class="intro">
        <h1>Julie Davila</h1>
        <p class="identity" class:list={[{ slot: !IDENTITY }]}>{identity}</p>
        <p class="thesis" class:list={[{ slot: !THESIS }]}>{thesis}</p>
        {brecha && <p class="brecha">{brecha}</p>}
        <nav class="chips" aria-label="Find me">
          <a href="https://linkedin.com/in/thisjulie">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
            <span>LinkedIn</span>
          </a>
          <a href="https://sf2framework.com">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            <span>SF²</span>
          </a>
        </nav>
      </div>
      <figure class="portrait">
        <img src="/portrait-azul.png" alt="Julie Davila" width="1600" height="1066" loading="eager" />
      </figure>
    </header>

    <hr />

    <section>
      <h2>Work</h2>
      <ul class="list">
        {work.map((w) => (
          <li>
            <a href={w.href}>{w.name}</a>
            <span class="note">{w.note}</span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Writing</h2>
      <ul class="list dated">
        {writing.map((p) => (
          <li>
            <span class="date">{p.date}</span>
            <span class="entry"><a href={p.href}>{p.title}</a><span class="note">{p.outlet}</span></span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Talks &amp; appearances</h2>
      <ul class="list dated">
        {appearances.map((a) => (
          <li>
            <span class="date">{a.date}</span>
            <span class="entry"><a href={a.href}>{a.title}</a></span>
          </li>
        ))}
      </ul>
    </section>

    <hr />

    <!-- The one action. The only terracotta on the page. -->
    <section class="action">
      <p class="soon">La Brecha — essays on the gaps, launching soon.</p>
      <a class="cta" href="mailto:julie@davila.io?subject=La%20Brecha">Tell me when it&rsquo;s live</a>
    </section>

    <footer>
      {elsewhere.map((e) => <a href={e.href}>{e.name}</a>)}
      <a href="mailto:julie@davila.io">Email</a>
    </footer>
  </main>
</body>
</html>

<style>
  main {
    max-width: 62rem;
    margin: 0 auto;
    padding: 9vh 1.5rem 8rem;
  }

  /* ── The fold: name is the hero, portrait is the plane ── */
  .fold {
    display: grid;
    grid-template-columns: 1.05fr 0.82fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;   /* top-align: name locks to portrait's top edge, no dead air below the chips */
    margin: 2vh 0 4.5rem; /* portrait sets the height; no min-height padding out a void */
  }

  h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(2.7rem, 6.5vw, 4.4rem);
    line-height: 1.0;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 1.1rem;
    text-wrap: balance;
  }

  .identity {
    font-family: var(--serif);
    font-size: clamp(1.15rem, 2.4vw, 1.55rem);
    line-height: 1.28;
    color: var(--azul);
    margin: 0 0 1.75rem;
    text-wrap: balance;
  }

  .thesis {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 1.9rem;
    max-width: 32rem;
  }

  .brecha {
    font-size: 1.02rem;
    color: var(--ink-soft);
    font-style: italic;
    margin: 0 0 1.5rem;
  }

  .chips { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .chips a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--sans);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--azul);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.45rem 0.95rem 0.45rem 0.8rem;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .chips svg { width: 0.95rem; height: 0.95rem; flex: none; }
  .chips a:hover { background: var(--azul); color: var(--sand); border-color: var(--azul); }

  /* Portrait as a Barragán plane: warm editorial B&W, an azul plane behind it. */
  .portrait {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 5;
    max-height: 68vh;
    justify-self: end;
    width: 100%;
  }
  .portrait::after {
    /* the azul plane — a real Barragán wall the portrait leans on, breaking the frame */
    content: '';
    position: absolute;
    right: -1.6rem;
    bottom: -1.6rem;
    width: 82%;
    height: 88%;
    background: var(--azul);
    z-index: 0;
  }
  .portrait img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 64% 26%;
    /* treatment is baked into the asset (screenprint) — no runtime filter */
    border-top: 3px solid var(--gold);
  }

  hr { border: 0; border-top: 1px solid var(--gold); margin: 3.5rem 0; }

  h2 {
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 1.25rem;
  }

  section { margin-bottom: 3rem; }

  .list { list-style: none; padding: 0; margin: 0; }
  .list li { margin-bottom: 1.1rem; line-height: 1.5; }

  .note { display: block; font-size: 0.92rem; color: var(--ink-soft); margin-top: 0.15rem; }

  .dated li {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }
  .date {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .entry .note { margin-top: 0.1rem; }

  .action { margin: 0 0 4rem; }
  .soon { font-size: 1.05rem; color: var(--ink); margin: 0 0 1rem; }

  /* The single terracotta. If you are adding a second one, stop. */
  .cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: var(--terracotta);
    border: 1px solid var(--terracotta);
    padding: 0.6rem 1.1rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .cta:hover { background: var(--terracotta); color: var(--sand); }

  footer {
    display: flex;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    font-family: var(--sans);
    font-size: 0.88rem;
  }
  footer a { color: var(--ink-soft); border-bottom: none; }
  footer a:hover { color: var(--azul); }

  @media (max-width: 56rem) {
    .fold {
      grid-template-columns: 1fr;
      gap: 2.25rem;
      min-height: 0;
    }
    .portrait {
      order: -1;
      max-height: 52vh;
      aspect-ratio: 3 / 2;
      justify-self: stretch;
    }
    .portrait img { object-position: 64% 22%; }
  }

  @media (max-width: 34rem) {
    main { padding-top: 6vh; }
    .dated li { grid-template-columns: 3rem 1fr; }
  }
</style>
